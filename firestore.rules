rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── ADMIN ──────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null
        && request.auth.uid == "efw85HN41nb1rmslevC3wkFpVUo1";
    }

    // ── APP HELPERS ────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    // ── ANALYTICS ──────────────────────────────────────────
    // Vedi internal/analytics-active-users.md.
    //
    // Top-level e NON sotto families/{familyId}: quel ramo è leggibile da ogni
    // membro (isMemberOrOwner), quindi il log delle letture diventerebbe un
    // registro di chi-ha-guardato-cosa consultabile dal partner.
    //
    // Append-only: il client scrive e non rilegge mai. Rollup e console passano
    // dall'Admin SDK, che bypassa le rules.
    match /analyticsEvents/{eventId} {
      // `expiresAt` è il campo della TTL policy (90gg): data di morte, non di
      // nascita. La policy NON va puntata su `ts`, che è già nel passato alla
      // scrittura e cancellerebbe ogni evento appena creato.
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(
             ['name', 'uid', 'familyId', 'feature', 'ts', 'expiresAt', 'props']);
      allow read, update, delete: if false;
    }

    // Rollup giornalieri: scritti dallo scheduler, letti solo dalla console.
    match /metrics/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    function isMember(familyId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid))
        && get(/databases/$(database)/documents/families/$(familyId)/members/$(request.auth.uid)).data.isDeleted != true;
    }

    function isOwner(familyId) {
      return isSignedIn() && (
        (resource != null && resource.data.ownerUid == request.auth.uid) ||
        get(/databases/$(database)/documents/families/$(familyId)).data.ownerUid == request.auth.uid
      );
    }

    function isMemberOrOwner(familyId) {
      return isOwner(familyId) || isMember(familyId);
    }

    // ── ADMIN: lettura globale, nessuna scrittura ──────────
    match /{document=**} {
      allow read:  if isAdmin();
      allow write: if false;
    }

    // ── USERS ──────────────────────────────────────────────
    match /users/{uid} {
      allow read, create, update, delete: if isSignedIn() && request.auth.uid == uid;

      match /memberships/{familyId} {
        allow read, create, update, delete: if isSignedIn() && request.auth.uid == uid;
      }

      match /fcmTokens/{tokenId} {
        allow read, create, update, delete: if isSignedIn() && request.auth.uid == uid;
      }

      // ── CHAT AI (private per-utente, sync cross-device) ────
      match /aiConversations/{conversationId} {
        allow read, create, update, delete: if isSignedIn() && request.auth.uid == uid;
      }
    }

    // ── FAMILIES ───────────────────────────────────────────
    match /families/{familyId} {
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid;

      allow read, update, delete: if isMemberOrOwner(familyId);

      match /members/{uid} {
        allow create, update, delete: if isSignedIn() && (uid == request.auth.uid || isOwner(familyId));
        allow get:  if isSignedIn() && (uid == request.auth.uid || isOwner(familyId));
        allow list: if isMemberOrOwner(familyId);
      }

      match /invites/{inviteId} {
        allow read, create: if isSignedIn();
        allow update: if isSignedIn()
          && resource.data.usedAt == null
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['usedAt', 'usedBy']);
        allow delete: if isMemberOrOwner(familyId);
      }

      match /counters/{uid} {
        allow get: if isSignedIn()
          && request.auth.uid == uid
          && isMemberOrOwner(familyId);
        allow create, update, delete: if false;
      }

      // ── Zone di arrivo (geofence) ─────────────────────────
      match /geofences/{geofenceId} {
        allow read: if isMemberOrOwner(familyId);
        allow create, update: if isMemberOrOwner(familyId);
        allow delete: if isOwner(familyId);
      }

      match /geofenceEvents/{eventId} {
        allow read: if isMemberOrOwner(familyId);
        allow create: if isMemberOrOwner(familyId)
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.type in ['arrive', 'leave']
          && request.resource.data.geofenceId is string
          && request.resource.data.geofenceId.size() > 0
          && request.resource.data.displayName is string
          && request.resource.data.keys().hasAll([
            'geofenceId', 'uid', 'displayName', 'type', 'timestamp'
          ]);
        allow update, delete: if false;
      }

      match /{subpath=**} {
        allow read: if isMemberOrOwner(familyId);
        allow write: if isMemberOrOwner(familyId)
          && subpath[0] != 'geofences'
          && subpath[0] != 'geofenceEvents';
      }
    }

    // ── INVITES (codici testuali flat) ─────────────────────
    match /invites/{code} {
      allow read, create: if isSignedIn();
      allow update: if isSignedIn()
        && resource.data.usedAt == null
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['usedAt', 'usedBy']);
      allow delete: if false;
    }

    // ── SUPPORT TICKETS (Assistente & Supporto) ───────────
    match /support_tickets/{ticketId} {
      function supportTicketRequiredKeys() {
        return [
          'id', 'familyId', 'uid', 'userEmail', 'type', 'title', 'summary',
          'conversation', 'images', 'platform', 'appVersion', 'osVersion',
          'device', 'status', 'createdAt',
        ];
      }

      function validSupportTicketData() {
        return request.resource.data.uid == request.auth.uid
          && request.resource.data.familyId is string
          && isMemberOrOwner(request.resource.data.familyId)
          && request.resource.data.type in ['question', 'bug', 'suggestion']
          && request.resource.data.status == 'new'
          && request.resource.data.platform in ['ios', 'android']
          && request.resource.data.keys().hasAll(supportTicketRequiredKeys())
          && request.resource.data.conversation is list
          && request.resource.data.images is list
          && request.resource.data.images.size() <= 5
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() <= 200
          && request.resource.data.summary is string
          && request.resource.data.summary.size() <= 2000
          && (
            !('rawLogs' in request.resource.data)
            || (
              request.resource.data.rawLogs is string
              && request.resource.data.rawLogs.size() <= 51200
            )
          );
      }

      allow create: if isSignedIn() && validSupportTicketData();

      allow update: if isAdmin()
        || (isSignedIn()
          && resource.data.uid == request.auth.uid
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.familyId == resource.data.familyId
          && validSupportTicketData());

      allow read: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);

      allow delete: if isAdmin();
    }

    // ── CRASH REPORTS (log anonimi, opt-in utente) ────────
    match /crash_reports/{reportId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.platform in ['ios', 'android']
        && request.resource.data.status == 'new'
        && request.resource.data.keys().hasAll([
          'platform', 'appVersion', 'osVersion', 'device',
          'issues', 'rawLogs', 'createdAt', 'status', 'userId'
        ])
        && request.resource.data.rawLogs is string
        && request.resource.data.rawLogs.size() <= 51200
        && request.resource.data.issues is list;
      allow read, update, delete: if false;
    }

    // ── DIAGNOSTICS ────────────────────────────────────────
    match /diagnostics/{doc} {
      allow read, write: if true;
    }
  }
}
