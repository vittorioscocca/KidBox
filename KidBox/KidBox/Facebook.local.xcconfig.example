//
//  Facebook.local.xcconfig.example
//  KidBox
//
//  Il progetto usa anche Facebook.local.xcconfig (versionato con placeholder).
//  In locale puoi modificare KidBox/KidBox/KidBox/Facebook.local.xcconfig con i valori reali
//  e usare `git update-index --skip-worktree` se non vuoi rischiare commit accidentali.
//
//  Xcode Cloud: imposta secret FACEBOOK_APP_ID_LOCAL e FACEBOOK_CLIENT_TOKEN_LOCAL nello
//  workflow; ci_scripts/ci_post_clone.sh sovrascrive il file prima della build.
//

// Non lasciare YOUR_META_* in build: l’SDK richiede fb<APP_ID> reale (allineato a Info.plist).
FACEBOOK_APP_ID_LOCAL = YOUR_META_APP_ID
FACEBOOK_CLIENT_TOKEN_LOCAL = YOUR_META_CLIENT_TOKEN
