          "stringUnit": {
            "state": "translated",
            "value": "L'assistant IA est disponible avec Pro ou Max"
          }
        }
      }
    },
    "L'assistente AI è incluso nei piani Pro e Max. Passa a Pro per 20 messaggi al giorno per membro.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The AI assistant is included in the Pro and Max plans. Upgrade to Pro for 20 messages a day per member."
          }
        },
        "es": {
          "stringUnit": {
