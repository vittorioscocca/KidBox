    "Tieni sotto controllo bollo, assicurazione, revisione e manutenzioni di ogni veicolo di famiglia, senza dimenticare le scadenze.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep track of road tax, insurance, inspection and maintenance for every family vehicle, without missing a deadline."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Controla el impuesto de circulación, el seguro, la ITV y el mantenimiento de cada vehículo de la familia, sin olvidar ningún plazo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gardez le contrôle de la taxe, de l'assurance, du contrôle technique et de l'entretien de chaque véhicule de la famille, sans manquer une échéance."
          }
        }
      }
    },
    "Tieni traccia di vaccini, visite veterinarie e promemoria per ogni animale domestico di famiglia.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep track of vaccines, vet visits and reminders for each family pet."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lleva el control de las vacunas, visitas al veterinario y recordatorios de cada mascota de la familia."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Suivez les vaccins, les visites vétérinaires et les rappels pour chaque animal de la famille."
          }
        }
      }
    },
