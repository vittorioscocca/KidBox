    "Lettura assistita dall'AI: più precisa di data/luogo/codice estratti automaticamente. Disponibile con il piano Max; consuma %lld messaggi.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "AI-assisted reading: more accurate than automatically extracted date/place/code. Available with the Max plan; consumes %lld messages."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lectura asistida por IA: más precisa que la fecha/lugar/código extraídos automáticamente. Disponible con el plan Max; consume %lld mensajes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lecture assistée par l'IA : plus précise que la date/le lieu/le code extraits automatiquement. Disponible avec le forfait Max ; consomme %lld messages."
          }
        }
      }
    },
