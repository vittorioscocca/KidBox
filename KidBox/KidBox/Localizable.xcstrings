    "Visite, accertamenti, cure e cartella clinica: lo storico completo, condiviso con chi se ne occupa insieme a te.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Visits, tests, treatments and medical records: the full history, shared with whoever looks after them with you."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Consultations, examens, traitements et dossier médical : l'historique complet, partagé avec ceux qui s'en occupent avec vous."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Visitas, pruebas, tratamientos e historial médico: el histórico completo, compartido con quien se ocupa de ellos contigo."
          }
        }
      }
    },
    "Visite, sport, compleanni: chi c'è, quando, e chi ci pensa. Senza rincorrersi a messaggi.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Appointments, sports, birthdays: who's going, when, and who's taking care of it. Without chasing each other over messages."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rendez-vous, sport, anniversaires : qui y va, quand, et qui s'en charge. Sans se courir après par messages."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Citas, deporte, cumpleaños: quién va, cuándo y quién se encarga. Sin perseguiros a mensajes."
          }
        }
      }
    },
