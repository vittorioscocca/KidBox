    "Abbiamo inviato un link di verifica a %@. Verifica l'indirizzo e poi accedi.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We sent a verification link to %@. Verify your address and then sign in."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hemos enviado un enlace de verificación a %@. Verifica la dirección y luego inicia sesión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous avons envoyé un lien de vérification à %@. Vérifiez l'adresse puis connectez-vous."
          }
        }
      }
    },
    "Abbiamo rilevato %lld %@. Puoi inviarci un report anonimo per aiutarci a risolvere il problema? Non verranno inviati dati personali o familiari.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We detected %lld %@. Can you send us an anonymous report to help us fix the problem? No personal or family data will be sent."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hemos detectado %lld %@. ¿Puedes enviarnos un informe anónimo para ayudarnos a resolver el problema? No se enviará ningún dato personal ni familiar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous avons détecté %lld %@. Pouvez-vous nous envoyer un rapport anonyme pour nous aider à résoudre le problème ? Aucune donnée personnelle ou familiale ne sera envoyée."
          }
        }
      }
    },
