    "Passa a Pro per accedere all'assistente che conosce calendario, spesa, salute dei tuoi figli, animali, casa, garage e molto altro.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Upgrade to Pro to access the assistant that knows your children's calendar, shopping, health, pets, home, garage and much more."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pasa a Pro para acceder al asistente que conoce el calendario, la compra, la salud de tus hijos, las mascotas, la casa, el garaje y mucho más."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Passez à Pro pour accéder à l'assistant qui connaît le calendrier, les courses, la santé de vos enfants, les animaux, la maison, le garage et bien plus."
          }
        }
      }
    },
