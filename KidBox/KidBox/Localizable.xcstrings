    "Scrivi note libere o formattate (grassetto, corsivo, liste) e scegli se condividerle con tutta la famiglia o tenerle solo per te.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Write free or formatted notes (bold, italic, lists) and choose whether to share them with the whole family or keep them just for yourself."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Escribe notas libres o con formato (negrita, cursiva, listas) y elige si compartirlas con toda la familia o guardarlas solo para ti."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Rédigez des notes libres ou formatées (gras, italique, listes) et choisissez de les partager avec toute la famille ou de les garder pour vous."
          }
        }
      }
    },
