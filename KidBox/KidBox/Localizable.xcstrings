    "Traccia le spese di famiglia per categoria, allega scontrini e foto e scopri a colpo d'occhio chi ha speso cosa e quando.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Track family expenses by category, attach receipts and photos, and see at a glance who spent what and when."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Registra los gastos familiares por categoría, adjunta recibos y fotos y descubre de un vistazo quién gastó qué y cuándo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Suivez les dépenses familiales par catégorie, joignez des tickets et des photos et découvrez d'un coup d'œil qui a dépensé quoi et quand."
          }
        }
      }
    },
