    "Invita l'altro genitore o gli altri membri: documenti, wallet, salute, spese e calendario diventano condivisi e aggiornati per tutti, in tempo reale.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Invite your partner or the other family members: documents, wallet, health, expenses and calendar become shared and up to date for everyone, in real time."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Invitez l'autre parent ou les autres membres : documents, wallet, santé, dépenses et calendrier deviennent partagés et à jour pour tout le monde, en temps réel."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Invita al otro progenitor o a los demás miembros: documentos, wallet, salud, gastos y calendario pasan a estar compartidos y actualizados para todos, en tiempo real."
          }
        }
      }
    },
