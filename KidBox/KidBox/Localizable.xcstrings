        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous pouvez aussi le faire plus tard depuis Réglages → Inviter un partenaire"
          }
        }
      }
    },
    "Puoi modificare il titolo e la data prima di salvare.": {
