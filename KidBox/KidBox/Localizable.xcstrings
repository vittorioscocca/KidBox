    "La nuova lingua verrà applicata al riavvio dell'app.": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The new language will be applied when you restart the app."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El nuevo idioma se aplicará al reiniciar la app."
          }
        },
