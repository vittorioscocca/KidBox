    "Condividi questo codice QR. L'altro genitore lo scannerizzerà per unirsi alla famiglia e ricevere automaticamente la chiave di cifratura.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Share this QR code. The other parent will scan it to join the family and automatically receive the encryption key."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Comparte este código QR. El otro progenitor lo escaneará para unirse a la familia y recibir automáticamente la clave de cifrado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Partagez ce QR code. L'autre parent le scannera pour rejoindre la famille et recevoir automatiquement la clé de chiffrement."
          }
        }
      }
    },
