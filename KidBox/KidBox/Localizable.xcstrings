    "Puoi allegare fino a 5 immagini per chiarire il problema (icona + sotto la chat).": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can attach up to 5 images to clarify the issue (icon below the chat)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes adjuntar hasta 5 imágenes para aclarar el problema (icono debajo del chat)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous pouvez joindre jusqu'à 5 images pour clarifier le problème (icône sous le chat)."
          }
        }
      }
    },
    "Puoi cambiare chi vede il documento in qualsiasi momento.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can change who sees the document at any time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes cambiar quién ve el documento en cualquier momento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous pouvez changer qui voit le document à tout moment."
          }
        }
      }
    },
    "Puoi chiedermi informazioni sulla preparazione, lo stato, il risultato o gli allegati.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can ask me about the preparation, status, result or attachments."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes preguntarme sobre la preparación, el estado, el resultado o los adjuntos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous pouvez me poser des questions sur la préparation, l'état, le résultat ou les pièces jointes."
          }
        }
      }
    },
    "Puoi chiedermi spiegazioni su diagnosi, farmaci, terapie o esami prescritti.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can ask me for explanations about diagnoses, medications, therapies or prescribed exams."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes pedirme explicaciones sobre diagnósticos, medicamentos, terapias o exámenes prescritos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous pouvez me demander des explications sur les diagnostics, médicaments, thérapies ou examens prescrits."
          }
        }
      }
    },
    "Puoi chiedermi un riassunto, l'andamento clinico, differenze tra visite, esami, farmaci o referti allegati.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can ask me for a summary, the clinical trend, differences between visits, exams, medications or attached reports."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes pedirme un resumen, la evolución clínica, diferencias entre visitas, exámenes, medicamentos o informes adjuntos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous pouvez me demander un résumé, l'évolution clinique, les différences entre visites, examens, médicaments ou comptes rendus joints."
          }
        }
      }
    },
    "Puoi chiedermi un riepilogo, farmaci in corso, vaccini, visite recenti o esami in attesa.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can ask me for an overview, current medications, vaccines, recent visits or pending exams."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes pedirme un resumen, medicamentos en curso, vacunas, visitas recientes o exámenes pendientes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous pouvez me demander un récapitulatif, les médicaments en cours, les vaccins, les visites récentes ou les examens en attente."
          }
        }
      }
    },
    "Puoi chiedermi un riepilogo, quali sono in scadenza, urgenti, con risultato disponibile o referti allegati.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can ask me for an overview, which are expiring, urgent, with a result available or attached reports."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes pedirme un resumen, cuáles están por vencer, urgentes, con resultado disponible o informes adjuntos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous pouvez me demander un récapitulatif, lesquels arrivent à échéance, urgents, avec un résultat disponible ou des comptes rendus joints."
          }
        }
      }
    },
    "Puoi crearne una nuova oppure entrare usando un codice invito.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can create a new one or join using an invite code."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes crear una nueva o unirte usando un código de invitación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous pouvez en créer une nouvelle ou en rejoindre une avec un code d'invitation."
          }
        }
      }
    },
    "Puoi disattivarlo in qualsiasi momento. I dati inviati all'AI sono quelli che scegli di condividere, visita per visita.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can turn it off at any time. The data sent to the AI is what you choose to share, visit by visit."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Puedes desactivarlo en cualquier momento. Los datos enviados a la IA son los que eliges compartir, visita por visita."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous pouvez le désactiver à tout moment. Les données envoyées à l'IA sont celles que vous choisissez de partager, visite par visite."
          }
        }
      }
    },
    "Puoi farlo anche dopo da Impostazioni → Invita partner": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You can also do it later from Settings → Invite partner"
