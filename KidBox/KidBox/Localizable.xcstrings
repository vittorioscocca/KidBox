    "Tocca «Aggiorna» per creare o aggiornare la cartella con visite, esami, referti e dati da Apple Salute (passi, battiti, sport).": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap «Update» to create or update the folder with visits, exams, reports and data from Apple Health (steps, heart rate, sports)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca «Actualizar» para crear o actualizar la carpeta con visitas, exámenes, informes y datos de Apple Salud (pasos, latidos, deporte)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Touchez « Actualiser » pour créer ou mettre à jour le dossier avec les visites, examens, comptes rendus et données d'Apple Santé (pas, rythme cardiaque, sport)."
