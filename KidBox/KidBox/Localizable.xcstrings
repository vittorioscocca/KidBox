    "Abilita KidBox come provider password in Impostazioni iOS per compilare automaticamente login e app.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable KidBox as a password provider in iOS Settings to autofill logins and apps."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activa KidBox como proveedor de contraseñas en los Ajustes de iOS para autocompletar inicios de sesión y apps."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez KidBox comme fournisseur de mots de passe dans les Réglages iOS pour remplir automatiquement les identifiants et les apps."
          }
        }
      }
    },
    "Abilita iCloud Keychain in Impostazioni > [Il tuo account] > iCloud > Portachiavi, oppure chiedi al proprietario della famiglia di condividere un QR code con la chiave.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable iCloud Keychain in Settings > [Your account] > iCloud > Keychain, or ask the family owner to share a QR code with the key."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activa el Llavero de iCloud en Ajustes > [Tu cuenta] > iCloud > Llavero, o pide al propietario de la familia que comparta un código QR con la clave."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez le Trousseau iCloud dans Réglages > [Votre compte] > iCloud > Trousseau, ou demandez au propriétaire de la famille de partager un QR code avec la clé."
          }
        }
      }
    },
    "Abilita le notifiche nelle Impostazioni per ricevere i promemoria.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable notifications in Settings to receive reminders."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Activa las notificaciones en los Ajustes para recibir los recordatorios."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez les notifications dans les Réglages pour recevoir les rappels."
          }
        }
      }
    },
