    "Gestisci i membri della famiglia, invita un nuovo genitore con un QR code e tieni sotto controllo chi fa parte del nucleo familiare.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Manage family members, invite a new parent with a QR code and keep track of who's part of the family."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Gestiona los miembros de la familia, invita a un nuevo progenitor con un código QR y controla quién forma parte del núcleo familiar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gérez les membres de la famille, invitez un nouveau parent avec un QR code et gardez le contrôle de qui fait partie du foyer."
          }
        }
      }
    },
