    "Questa azione eliminerà cartelle e documenti selezionati in locale e in remoto su tutti i dispositivi.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This action will delete the selected folders and documents locally and remotely on all devices."
          }
