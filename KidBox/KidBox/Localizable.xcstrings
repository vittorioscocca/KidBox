    "Conosce salute, visite, esami, documenti, wallet e password": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Knows health, visits, exams, documents, wallet and passwords"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Conoce salud, visitas, exámenes, documentos, wallet y contraseñas"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Connaît santé, visites, examens, documents, wallet et mots de passe"
          }
        }
      }
    },
    "Conosco il tuo calendario, i to-do, le cure, visite ed esami, i documenti, il wallet, le note, le spese e le scadenze sanitarie.\nChiedimi qualsiasi cosa.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "I know your calendar, to-dos, treatments, visits and exams, documents, wallet, notes, expenses and health deadlines.\nAsk me anything."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Conozco tu calendario, tus tareas, los tratamientos, visitas y exámenes, los documentos, la wallet, las notas, los gastos y los vencimientos de salud.\nPregúntame lo que quieras."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Je connais votre calendrier, vos to-dos, vos traitements, visites et examens, vos documents, votre wallet, vos notes, vos dépenses et vos échéances de santé.\nDemandez-moi ce que vous voulez."
          }
        }
      }
    },
