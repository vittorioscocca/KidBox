    "NSCameraUsageDescription" : {
      "comment" : "Privacy - Camera Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Used to take and save documents/photos in KidBox."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se usa para hacer y guardar documentos/fotos en KidBox."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sert à prendre et enregistrer des documents/photos dans KidBox."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Serve per scattare e salvare documenti/foto in KidBox."
          }
        }
      }
    },
    "NSContactsUsageDescription" : {
      "comment" : "Privacy - Contacts Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "KidBox uses your contacts to let you share a contact in chat."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "KidBox usa tus contactos para permitirte compartir un contacto en el chat."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "KidBox utilise vos contacts pour vous permettre de partager un contact dans le chat."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "KidBox usa i contatti per permetterti di condividere un contatto in chat."
          }
        }
      }
    },
    "NSHealthShareUsageDescription" : {
      "comment" : "Privacy - Health Share Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "KidBox reads weight, blood type, heart rate and activity from Apple Health to fill in the medical record."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "KidBox lee el peso, el grupo sanguíneo, la frecuencia cardíaca y la actividad de Apple Salud para rellenar la ficha médica."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "KidBox lit le poids, le groupe sanguin, la fréquence cardiaque et l'activité depuis Apple Santé pour remplir la fiche médicale."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "KidBox legge peso, gruppo sanguigno, frequenza cardiaca e attività da Apple Salute per compilare la scheda medica."
          }
        }
      }
    },
    "NSHealthUpdateUsageDescription" : {
      "comment" : "Privacy - Health Update Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "KidBox does not write data to Apple Health."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "KidBox no escribe datos en Apple Salud."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "KidBox n'écrit aucune donnée dans Apple Santé."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "KidBox non scrive dati in Apple Salute."
          }
        }
      }
    },
    "NSLocationAlwaysAndWhenInUseUsageDescription" : {
      "comment" : "Privacy - Location Always and When In Use Usage Description",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "KidBox uses your location in the background to update it even when the app isn't open."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "KidBox usa tu ubicación en segundo plano para actualizarla incluso cuando la app no está abierta."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "KidBox utilise votre position en arrière-plan pour la mettre à jour même lorsque l'app n'est pas ouverte."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "KidBox usa la tua posizione in background per aggiornarla anche quando l'app non è aperta."
          }
        }
      }
    },
