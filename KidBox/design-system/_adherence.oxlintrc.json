{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/ai/**",
              "components/cards/**",
              "components/core/**",
              "ui_kits/mobile-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Nunito))/i]",
        "message": "Font not provided by the design system. Available: Nunito."
      },
      {
        "selector": "JSXOpeningElement[name.name='AskAIButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|label|pulse|onClick|style|key|ref|className|style|children)$/]",
        "message": "<AskAIButton> doesn't accept that prop. Declared props: size, label, pulse, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='AskAIButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:fab|sm)$/]",
        "message": "<AskAIButton> size must be one of 'fab' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, name, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:count|max|tone|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: count, max, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:danger|orange|green|blue)$/]",
        "message": "<Badge> tone must be one of 'danger' | 'orange' | 'green' | 'blue'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|iconRight|fullWidth|disabled|onClick|type|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, iconRight, fullWidth, disabled, onClick, type, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|accent|ai|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'accent' | 'ai' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|hint|icon|syncLabel|syncTone|onClick|style|key|ref|className|style|children)$/]",
        "message": "<CategoryCard> doesn't accept that prop. Declared props: title, hint, icon, syncLabel, syncTone, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryCard'] > JSXAttribute[name.name='syncTone'] > Literal[value!=/^(?:green|orange|red)$/]",
        "message": "<CategoryCard> syncTone must be one of 'green' | 'orange' | 'red'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tint|variant|icon|style|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: children, tint, variant, icon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:neutral|tinted)$/]",
        "message": "<Chip> variant must be one of 'neutral' | 'tinted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='HeroCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|dateText|badgeText|photo|actionLabel|height|onClick|style|key|ref|className|style|children)$/]",
        "message": "<HeroCard> doesn't accept that prop. Declared props: title, subtitle, dateText, badgeText, photo, actionLabel, height, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='HomeCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|icon|tint|badge|locked|onClick|style|key|ref|className|style|children)$/]",
        "message": "<HomeCard> doesn't accept that prop. Declared props: title, subtitle, icon, tint, badge, locked, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='InviteCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|icon|onClick|style|key|ref|className|style|children)$/]",
        "message": "<InviteCard> doesn't accept that prop. Declared props: title, subtitle, icon, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SettingsCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|icon|tone|trailing|onClick|children|style|key|ref|className|style|children)$/]",
        "message": "<SettingsCard> doesn't accept that prop. Declared props: title, subtitle, icon, tone, trailing, onClick, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SettingsCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:primary|secondary|info|warning|danger)$/]",
        "message": "<SettingsCard> tone must be one of 'primary' | 'secondary' | 'info' | 'warning' | 'danger'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
